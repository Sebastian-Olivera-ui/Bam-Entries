$ErrorActionPreference = 'SilentlyContinue'

function Get-Signature {
    [CmdletBinding()]
    param (
        [Parameter(Mandatory, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [string[]]$FilePath
    )

    process {
        foreach ($path in $FilePath) {
            if (-not (Test-Path -Path $path -PathType Leaf)) {
                [PSCustomObject]@{
                    FilePath  = $path
                    Signature = 'El archivo no fue encontrado'
                }
                continue
            }

            $status = (Get-AuthenticodeSignature -FilePath $path -ErrorAction SilentlyContinue).Status
            $signatureText = switch ($status) {
                'Valid'       { 'Firma Valida' }
                'NotSigned'   { 'Firma Invalida (No esta firmado)' }
                'HashMismatch' { 'Firma Invalida (HashMismatch)' }
                'NotTrusted'  { 'Firma Invalida (NotTrusted)' }
                'UnknownError' { 'Firma Invalida (UnknownError)' }
                default       { 'Firma Invalida (UnknownError)' }
            }

            [PSCustomObject]@{
                FilePath  = $path
                Signature = $signatureText
            }
        }
    }
}

